<local:TaskbarAnchoredFlyoutWindow x:Class="PrayerTray.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PrayerTray.Views"
        xmlns:controls="clr-namespace:PrayerTray.Controls"
        Title="{DynamicResource Settings}"
        Width="360"
        Height="680">
    <Border Style="{StaticResource FlyoutSurface}">
        <Grid Background="#FF202020">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="{DynamicResource Settings}"
                       Style="{StaticResource FlyoutTitle}"
                       Margin="0,0,0,14" />

            <ScrollViewer Grid.Row="1" Style="{StaticResource FlyoutScrollViewer}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource General}"
                               Style="{StaticResource FlyoutSectionTitle}" />

                    <controls:SettingsComboRow Title="{DynamicResource Language}"
                                               ItemsSource="{Binding Languages}"
                                               DisplayMemberPath="DisplayName"
                                               SelectedValuePath="Code"
                                               SelectedValue="{Binding SelectedLanguage}" />

                    <controls:SettingsComboRow Title="{Binding TimeFormatTitle}"
                                               ItemsSource="{Binding TimeFormatOptions}"
                                               DisplayMemberPath="Name"
                                               SelectedValuePath="Value"
                                               SelectedValue="{Binding SelectedTimeFormat}" />

                    <controls:SettingsComboRow Title="{Binding TaskbarContentModeTitle}"
                                               ItemsSource="{Binding TaskbarContentModeOptions}"
                                               DisplayMemberPath="Name"
                                               SelectedValuePath="Value"
                                               SelectedValue="{Binding SelectedTaskbarContentMode}" />

                    <TextBlock Text="{DynamicResource Location}"
                               Style="{StaticResource FlyoutSectionTitle}"
                               Margin="0,14,0,8" />

                    <controls:SettingsToggleRow Title="{Binding ManualLocationTitle}"
                                                IsOn="{Binding UseManualLocation}" />

                    <TextBlock Text="{Binding DetectedLocationText}"
                               Style="{StaticResource FlyoutStatusText}"
                               Margin="0,0,0,8"
                               Visibility="{Binding UseManualLocation, Converter={StaticResource BooleanToVisibilityInverted}}" />

                    <Border ClipToBounds="True" Margin="0,0,0,14">
                        <StackPanel IsEnabled="{Binding UseManualLocation}">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="MaxHeight" Value="0" />
                                    <Setter Property="Opacity" Value="0" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UseManualLocation}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="MaxHeight"
                                                                         To="110"
                                                                         Duration="0:0:0.25">
                                                            <DoubleAnimation.EasingFunction>
                                                                <CubicEase EasingMode="EaseOut" />
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         To="1"
                                                                         Duration="0:0:0.2" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="MaxHeight"
                                                                         To="0"
                                                                         Duration="0:0:0.2">
                                                            <DoubleAnimation.EasingFunction>
                                                                <CubicEase EasingMode="EaseIn" />
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         To="0"
                                                                         Duration="0:0:0.15" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <controls:SettingsContentRow Title="{DynamicResource City}">
                                <controls:SettingsContentRow.RowContent>
                                    <controls:CitySearchBox SearchText="{Binding CitySearchText, UpdateSourceTrigger=PropertyChanged}"
                                                            Results="{Binding CitySearchResults}"
                                                            SelectedCity="{Binding SelectedCity, Mode=TwoWay}"
                                                            IsSearching="{Binding IsSearchingCities}" />
                                </controls:SettingsContentRow.RowContent>
                            </controls:SettingsContentRow>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{DynamicResource Taskbar}"
                               Style="{StaticResource FlyoutSectionTitle}"
                               Margin="0,0,0,8" />

                    <controls:SettingsToggleRow Title="{Binding StartWithWindowsTitle}"
                                                IsOn="{Binding StartWithWindows}" />
                    <controls:SettingsToggleRow Title="{Binding ShowWidgetTitle}"
                                                IsOn="{Binding ShowWidget}" />
                    <controls:SettingsToggleRow Title="{Binding ShowNotificationIconTitle}"
                                                IsOn="{Binding ShowNotificationIcon}" />
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2"
                        HorizontalAlignment="Center"
                        Margin="0,6,0,2">
                <TextBlock Text="{DynamicResource FooterMadeByMar}"
                           Style="{StaticResource FlyoutStatusText}"
                           TextAlignment="Center"
                           Margin="0,0,0,3" />

                <Button Click="OnSupportButtonClick"
                        Style="{StaticResource FlyoutImageLinkButton}"
                        ToolTip="{DynamicResource FooterSupportProject}"
                        AutomationProperties.Name="{DynamicResource FooterSupportProject}">
                    <Image Source="pack://application:,,,/Resources/Images/support-me-on-patreon-transparent.png"
                           Width="120"
                           Stretch="Uniform"
                           SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                </Button>
            </StackPanel>

            <TextBlock Grid.Row="3"
                       Text="{Binding StatusMessage}"
                       Style="{StaticResource FlyoutStatusText}" />

            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="{DynamicResource Cancel}"
                        Click="OnCancelClick"
                        Style="{StaticResource FlyoutButton}"
                        Margin="0,0,8,0" />
                <Button Content="{DynamicResource Save}"
                        Click="OnSaveClick"
                        Style="{StaticResource FlyoutPrimaryButton}"
                        IsDefault="True" />
            </StackPanel>
        </Grid>
    </Border>
</local:TaskbarAnchoredFlyoutWindow>
