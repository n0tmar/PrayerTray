<local:TaskbarAnchoredFlyoutWindow x:Class="PrayerTray.Views.PrayerFlyoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PrayerTray.Views"
        Title="{DynamicResource PrayerTimes}"
        Width="360"
        Height="400">
    <Border Style="{StaticResource FlyoutSurface}">
        <Grid Background="#FF202020">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,14">
                <TextBlock Text="{DynamicResource PrayerTimes}"
                           Style="{StaticResource FlyoutTitle}" />
                <TextBlock Text="{Binding LocationText}"
                           Style="{StaticResource FlyoutSubtitle}" />
            </StackPanel>

            <ItemsControl Grid.Row="1" ItemsSource="{Binding Prayers}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="10,8"
                                Margin="0,1"
                                CornerRadius="4"
                                Background="{Binding IsHighlighted, Converter={StaticResource HighlightConverter}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding DisplayName}"
                                           FontFamily="Segoe UI Variable Text"
                                           FontSize="13"
                                           Foreground="#FFFFFF" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding TimeText}"
                                           FlowDirection="LeftToRight"
                                           FontFamily="Segoe UI Variable Text"
                                           FontSize="13"
                                           Typography.StylisticSet1="True"
                                           Foreground="#D9FFFFFF" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,12,0,0">
                <Button Content="{DynamicResource Refresh}"
                        Click="OnRefreshLocationClick"
                        Style="{StaticResource FlyoutButton}" />
                <Button Content="{DynamicResource Settings}"
                        Click="OnSettingsClick"
                        Style="{StaticResource FlyoutButton}"
                        Margin="8,0,0,0" />
            </StackPanel>
        </Grid>
    </Border>
</local:TaskbarAnchoredFlyoutWindow>
