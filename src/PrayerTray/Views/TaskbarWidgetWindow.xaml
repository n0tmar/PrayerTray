<Window x:Class="PrayerTray.Views.TaskbarWidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PrayerTray"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Focusable="False"
        ShowActivated="False">
    <Canvas x:Name="WidgetCanvas" Background="Transparent">
        <Border x:Name="WidgetHost"
                Padding="0,0,2,0"
                Background="Transparent"
                Cursor="Hand"
                MouseLeftButtonUp="OnMouseLeftButtonUp"
                MouseRightButtonUp="OnMouseRightButtonUp">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Right">
                <TextBlock x:Name="TopLineText"
                           Style="{StaticResource TaskbarLineStyle}"
                           Text="{Binding TopLine}" />
                <TextBlock x:Name="BottomLineText"
                           Style="{StaticResource TaskbarLineStyle}"
                           Text="{Binding BottomLine}" />
            </StackPanel>
        </Border>
    </Canvas>
</Window>
