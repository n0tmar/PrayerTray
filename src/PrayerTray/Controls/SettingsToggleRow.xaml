<UserControl x:Class="PrayerTray.Controls.SettingsToggleRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             MinHeight="32"
             Margin="0,0,0,2">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0"
                   Style="{StaticResource FlyoutSettingTitle}"
                   VerticalAlignment="Center"
                   Margin="0,0,12,0">
            <TextBlock.Text>
                <Binding Path="Title" ElementName="Root" />
            </TextBlock.Text>
        </TextBlock>

        <CheckBox Grid.Column="1"
                  VerticalAlignment="Center"
                  IsChecked="{Binding IsOn, ElementName=Root, Mode=TwoWay}"
                  Style="{StaticResource FlyoutToggleSwitch}" />
    </Grid>
</UserControl>
