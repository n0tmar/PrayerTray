<UserControl x:Class="PrayerTray.Controls.SettingsContentRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             Margin="0,0,0,8">
    <StackPanel>
        <TextBlock Text="{Binding Title, ElementName=Root}"
                   Style="{StaticResource FlyoutSettingTitle}"
                   Margin="0,0,0,4" />

        <ContentControl Content="{Binding RowContent, ElementName=Root}" />
    </StackPanel>
</UserControl>
