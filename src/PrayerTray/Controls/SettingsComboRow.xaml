<UserControl x:Class="PrayerTray.Controls.SettingsComboRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             MinHeight="58"
             Margin="0,0,0,12">
    <StackPanel>
        <TextBlock Text="{Binding Title, ElementName=Root}"
                   Style="{StaticResource FlyoutSettingTitle}"
                   Margin="0,0,0,4" />

        <ComboBox ItemsSource="{Binding ItemsSource, ElementName=Root}"
                  DisplayMemberPath="{Binding DisplayMemberPath, ElementName=Root}"
                  SelectedValuePath="{Binding SelectedValuePath, ElementName=Root}"
                  SelectedValue="{Binding SelectedValue, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                  Style="{StaticResource FlyoutComboBox}" />
    </StackPanel>
</UserControl>
