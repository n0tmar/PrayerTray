<UserControl x:Class="PrayerTray.Controls.CitySearchBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="30">
    <ComboBox x:Name="CityCombo"
              Style="{StaticResource FlyoutCitySearchComboBox}"
              IsEditable="True"
              IsTextSearchEnabled="False"
              StaysOpenOnEdit="True"
              MaxDropDownHeight="220"
              Margin="0,0,0,10"
              Text="{Binding SearchText, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
              ItemsSource="{Binding Results, RelativeSource={RelativeSource AncestorType=UserControl}}"
              SelectedItem="{Binding SelectedCity, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
              DisplayMemberPath="DisplayName" />
</UserControl>
